<Page x:Class="MathChain.WPF.Views.ExercisePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:viewmodels="clr-namespace:MathChain.WPF.ViewModels"
      xmlns:converters="clr-namespace:MathChain.WPF.Converters"
      xmlns:helix="http://helix-toolkit.org/wpf"
      xmlns:math="clr-namespace:WpfMath.Controls;assembly=WpfMath"
      Title="ExercisePage">


    <Grid Background="#1A1A2E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Margin="20,20,0,20">
            <TextBlock Text="Arena: Integral Practice" Foreground="#00D4FF" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Column="0" Grid.Row="1" Background="#101020" Margin="20,0,20,0" CornerRadius="8" BorderThickness="1" BorderBrush="#3A3A50">

            <math:FormulaControl x:Name="FormulaDisplay" 
                         Formula="\text{Loading problem from Wolfram...}" 
                         Foreground="White" 
                         HorizontalAlignment="Center" 
                         VerticalAlignment="Center" 
                         Scale="40"/>

        </Border>

        <StackPanel Grid.Column="0" Grid.Row="2" Margin="20,20,0,20">
            <TextBlock Text="Enter your result (number with maximum 3 decimal places):" Foreground="White" Opacity="0.8" Margin="0,0,0,10"/>
            <TextBox x:Name="AnswerBox" 
                     Height="50" Width="300" HorizontalAlignment="Left"
                     Background="#101020" Foreground="White" 
                     BorderBrush="#00D4FF" BorderThickness="1" 
                     FontSize="20" Padding="10"/>
        </StackPanel>

        <Grid Grid.Column="0" Grid.Row="3" Margin="20,10,20,20">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Exit" Width="100" Height="45" Margin="0,0,10,0"
                        Background="#2A2A40" Foreground="#00D4FF" FontSize="16" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#00D4FF"/>
                <Button Content="Previous" Width="100" Height="45" Margin="0,0,10,0"
                        Background="#2A2A40" Foreground="#00D4FF" FontSize="16" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#00D4FF"/>

                <Button Content="Hint" Width="100" Height="45" Margin="0,0,10,0"
                        Background="#2A2A40" Foreground="#00D4FF" FontSize="16" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#00D4FF"/>

                <Button Content="View Solution" Width="130" Height="45"
                        Background="#2A2A40" Foreground="#00D4FF" FontSize="16" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#00D4FF"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Verify Answer" Width="150" Height="45" Margin="0,0,10,0"
                        Background="#00D4FF" Foreground="#1A1A2E" FontSize="16" FontWeight="Bold" BorderThickness="0" Click="VerifyAnswer_Click"/>

                <Button Content="Next" Width="100" Height="45"
                        Background="#00D4FF" Foreground="#1A1A2E" FontSize="16" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>

        </Grid>

        <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="4" Background="#2A2A40" Margin="0,20,20,20" CornerRadius="10">
            <TextBlock Text="Scientific Calculator Layout" 
                       Foreground="White" Opacity="0.3" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>

    </Grid>


</Page>
