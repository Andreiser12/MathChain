<Page x:Class="MathChain.WPF.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoginPage"
      Background="#1A1A2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="." 
                Background="Transparent" 
                BorderBrush="Transparent" 
                Foreground="#1A1A2E" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Bottom" 
                Click="SecretBypass_Click"/>
        
        <TextBlock Grid.Row="0"
                   Text="MathChain"
                   Foreground="#00D4FF"
                   FontSize="36"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1"
                Width="250" Height="250"
                Background="White"
                Padding="10"
                HorizontalAlignment="Center">
            <Image x:Name="QRCodeImage"
                   Stretch="Uniform"/>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="Scan with MetaMask Mobile"
                   Foreground="#E0E0FF"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,10"/>

        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Text="Waiting for connection..."
                   Foreground="#7B2FBE"
                   FontSize="14"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
    </Grid>
</Page>