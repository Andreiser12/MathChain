<Window x:Class="MathChain.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MathChain" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#1A1A2E" HorizontalAlignment="Stretch">
            <TextBlock Text="MathChain" 
                       HorizontalAlignment="Center"
                       Foreground="#00D4FF"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="20,20,0,20"/>
            <Button Content="Dashboard" 
                    Margin="20,0,20,10"
                    Padding="10"
                    Height="50"
                    Background="#1A1A2E"
                    Foreground="#00D4FF"
                    BorderBrush="#00D4FF"
                    Click="DashboardButton_Click"/>
            <Button Content="Chapters" 
                    Margin="20,0,20,10"
                    Padding="10"
                    Height="50"
                    Background="#1A1A2E"
                    Foreground="#00D4FF"
                    BorderBrush="#00D4FF"
                    Click="ChaptersButton_Click"/>
            <Button Content="Settings" 
                    Margin="20,0,20,10"
                    Padding="10"
                    Height="50"
                    Background="#1A1A2E"
                    Foreground="#00D4FF"
                    BorderBrush="#00D4FF"
                    Click="SettingsButton_Click"/>
            <Button Content="Account" 
                    Margin="20,0,20,10"
                    Padding="10"
                    Height="50"
                    Background="#1A1A2E"
                    Foreground="#00D4FF"
                    BorderBrush="#00D4FF"
                    Click="AccountButton_Click"/>
        </StackPanel>

        <Frame x:Name="MainFrame" 
               Grid.Column="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>