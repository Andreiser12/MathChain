@inherits LayoutComponentBase
@inject AppSession Session
@inject NavigationManager Nav

<MudThemeProvider Theme="@_mudTheme" IsDarkMode=true />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

	@if (Session.IsConnected)
	{
		@if (!IsPracticePage())

		{
			<MudAppBar>

				<MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
							   Color="Color.Inherit" OnClick="GoBack" Align="Align.Start">

				</MudIconButton>
			</MudAppBar>
		}

		<MudDrawer @bind-Open="_drawerOpen"
				   Elevation="2">
			<MudNavMenu>
				<MudText Typo="Typo.h5"
						 Color="Color.Primary"
						 Align="Align.Center"
						 Class="my-4">
					Mathchain
				</MudText>
				<MudDivider />
				<MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
				<MudDivider />
				<MudNavLink Href="/chapters" Icon="@Icons.Material.Filled.MenuBook">Chapters</MudNavLink>
				<MudDivider />
				<MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
				<MudDivider />
				<MudNavLink Href="/account" Icon="@Icons.Material.Filled.AccountCircle">Account</MudNavLink>
				<MudDivider />
			</MudNavMenu>
		</MudDrawer>

	}

	<MudMainContent Style="@(IsPracticePage() ? "padding-top: 0 !important;" : "")">
		@Body
	</MudMainContent>

</MudLayout>

@code
{
	private MudTheme _mudTheme = new MudTheme()
	{
		PaletteDark = new PaletteDark()
		{
			Primary = Colors.Indigo.Accent4,
			Background = "#1A1A2E",
			Surface = "#16213E",
			AppbarBackground = "#0F3460"
		}
	};

	private bool _drawerOpen = true;

	private void DrawerToggle()
	{
		_drawerOpen = !_drawerOpen;
	}

	private bool IsPracticePage()
	{
		return Nav.Uri.Contains("/practice");
	}

	void GoBack()
	{
		Nav.NavigateTo("javascript:history.back()");
	}
}
